# Auth.js v5
AUTH_SECRET=          # Generate with: npx auth secret
AUTH_GOOGLE_ID=       # Google OAuth Client ID
AUTH_GOOGLE_SECRET=   # Google OAuth Client Secret

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/jobseeker
DIRECT_URL=postgresql://user:password@localhost:5432/jobseeker

# Admin
ADMIN_EMAILS=admin@example.com   # Comma-separated admin emails

# Resume Generation (Anthropic)
ANTHROPIC_API_KEY=               # Anthropic API key for Claude
CLAUDE_MODEL=claude-sonnet-4-20250514   # Claude model ID (optional)

# Rate Limiting (Upstash Redis — optional)
UPSTASH_REDIS_REST_URL=          # Upstash Redis REST URL
UPSTASH_REDIS_REST_TOKEN=        # Upstash Redis REST token

# Ko-fi Donations (optional)
NEXT_PUBLIC_KOFI_ID=             # Ko-fi username for support button
